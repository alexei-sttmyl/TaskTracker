@page
@model TaskTracker.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h3 class="mb-0">🔑 Вход в аккаунт</h3>
            </div>
            <div class="card-body">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:none;"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold">Пароль</label>
                        <input asp-for="Input.Password" class="form-control" type="password" autocomplete="current-password" aria-required="true" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" name="Input.RememberMe" value="true" class="form-check-input" id="RememberMe" @(Model.Input.RememberMe ? "checked" : "") />
                            <input type="hidden" name="Input.RememberMe" value="false" />
                            <label for="RememberMe" class="form-check-label">Запомнить меня</label>
                        </div>
                    </div>

                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                    <div class="d-grid">
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg">Войти</button>
                    </div>

                    <div class="mt-3 text-center">
                        <p>
                            Нет аккаунта?
                            <a href="@Url.Page("./Register", new { returnUrl = Model.ReturnUrl })">Зарегистрироваться</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const summary = document.querySelector('[asp-validation-summary="ModelOnly"]');
            if (summary && summary.textContent.trim()) {
                summary.style.display = 'block';
            }
        });
    </script>
}
