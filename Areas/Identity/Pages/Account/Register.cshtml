@page
@model TaskTracker.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center">
                <h3 class="mb-0">🎉 Создание аккаунта</h3>
            </div>
            <div class="card-body">
                <form id="registerForm" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:none;"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold">Email</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold">Пароль</label>
                        <input asp-for="Input.Password" class="form-control" type="password" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                        <div class="form-text">Пароль должен содержать минимум 6 символов.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-bold">Подтвердите пароль</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" aria-required="true" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                    <div class="d-grid">
                        <button id="registerSubmit" type="submit" class="btn btn-success btn-lg">Зарегистрироваться</button>
                    </div>

                    <div class="mt-3 text-center">
                        <p>
                            Уже есть аккаунт?
                            <a href="@Url.Page("./Login", new { returnUrl = Model.ReturnUrl })">Войти</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const summary = document.querySelector('[asp-validation-summary="ModelOnly"]');
            const errors = document.querySelectorAll('.text-danger');
            if (summary && summary.textContent.trim()) {
                summary.style.display = 'block';
            }
        });
    </script>
}
