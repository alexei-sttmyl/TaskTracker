@model TaskTracker.ViewModels.HabitViewModel

@{
    ViewData["Title"] = "Детали — " + Model.Name;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад к списку</a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">📊 @Model.Name</h4>
                <span class="badge bg-light text-dark">ID: @Model.Id</span>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-3">
                        <h6 class="fw-bold">Описание</h6>
                        <p class="text-muted">@Model.Description</p>
                    </div>
                }

                <div class="row text-center mb-4">
                    <div class="col-md-3 col-6 mb-3">
                        <div class="border rounded p-3">
                            <div class="fw-bold fs-2 text-primary">@Model.TodayCount</div>
                            <small class="text-muted">Сегодня</small>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="border rounded p-3">
                            <div class="fw-bold fs-2 @(Model.Streak >= 7 ? "text-danger" : Model.Streak >= 3 ? "text-warning" : "text-muted")">🔥 @Model.Streak</div>
                            <small class="text-muted">дней подряд</small>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="border rounded p-3">
                            <div class="fw-bold fs-2 text-success">@Model.TotalCompletions</div>
                            <small class="text-muted">всего выполнений</small>
                        </div>
                    </div>
                    <div class="col-md-3 col-6 mb-3">
                        <div class="border rounded p-3">
                            <div class="fw-bold fs-2 text-info">🎯 @Model.DailyGoal</div>
                            <small class="text-muted">цель/день</small>
                        </div>
                    </div>
                </div>

                @{
                    var progressPercent = Model.DailyGoal > 0 ? Math.Min(100, (int)((double)Model.TodayCount / Model.DailyGoal * 100)) : 0;
                }
                <h6 class="fw-bold">Прогресс за сегодня</h6>
                <div class="progress mb-3" style="height: 25px;">
                    <div class="progress-bar @(progressPercent >= 100 ? "bg-success" : "bg-warning")" role="progressbar"
                         style="width: @progressPercent%">
                        @Model.TodayCount / @Model.DailyGoal (@progressPercent%)
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <strong>📅 Дата начала:</strong> @Model.StartDate.ToString("dd.MM.yyyy HH:mm")
                    </div>
                    <div class="col-md-6">
                        <strong>🎯 Цель (дней):</strong> @(Model.TargetDays?.ToString() ?? "Не задана")
                    </div>
                </div>

                @if (Model.TargetDays.HasValue)
                {
                    var daysElapsed = (DateTime.Now.Date - Model.StartDate.Date).Days;
                    var progress = Math.Min(100, (int)((double)daysElapsed / Model.TargetDays * 100));
                    <div class="mt-3">
                        <strong>Прогресс цели:</strong> @daysElapsed / @Model.TargetDays дней
                        <div class="progress mt-1" style="height: 10px;">
                            <div class="progress-bar bg-info" role="progressbar" style="width: @progress%"></div>
                        </div>
                    </div>
                }
            </div>
            <div class="card-footer bg-transparent">
                <div class="btn-group w-100" role="group">
                    <a asp-action="Complete" asp-route-id="@Model.Id" class="btn btn-success">✅ Отметить</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">✏️ Редактировать</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">🗑️ Удалить</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">📅 Все выполнения</h5>
                <span class="badge bg-secondary">@Model.RecentLogs.Count записей</span>
            </div>

            <div class="card-body p-0">
                @if (Model.RecentLogs.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <p class="mb-0">Выполнений пока нет</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Дата и время</th>
                                    <th class="text-center">Выполнено</th>
                                    <th class="text-center">Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.RecentLogs)
                                {
                                    <tr class="@(log.GoalMet ? "table-success" : "")">
                                        <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td class="text-center">@log.CompletionCount / @Model.DailyGoal</td>
                                        <td class="text-center">@(log.GoalMet ? "✅" : "❌")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
