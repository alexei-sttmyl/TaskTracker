@{
    ViewData["Title"] = "Главная";
}

<div class="text-center py-5">
    <h1 class="display-4 mb-3">🎯 Добро пожаловать в TaskTracker</h1>
    <p class="lead text-muted mb-4">
        Отслеживайте привычки, формируйте полезные ритуалы и достигайте своих целей!
    </p>

    <div class="row justify-content-center g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-1 mb-3">📋</div>
                    <h5>Создавайте привычки</h5>
                    <p class="text-muted">Укажите название, описание и ежедневную цель</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-1 mb-3">✅</div>
                    <h5>Отмечайте каждый день</h5>
                    <p class="text-muted">Фиксируйте прогресс одним нажатием</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-1 mb-3">🔥</div>
                    <h5>Следите за серией</h5>
                    <p class="text-muted">Мотивируйтесь streak и не прерывайте цепочку</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Habit" asp-action="Index" class="btn btn-primary btn-lg me-2">
            📋 Мои привычки
        </a>
        <a asp-controller="Habit" asp-action="Create" class="btn btn-outline-primary btn-lg">
            ➕ Создать привычку
        </a>
    </div>
</div>
